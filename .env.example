# --- Firebase Authentication ---
# ID del proyecto de Firebase. Se usa para validar los claims iss/aud del ID token.
FIREBASE_PROJECT_ID=your-firebase-project-id
# Allowlist de emails autorizados como admin, separados por comas (case-insensitive).
ADMIN_EMAILS=admin@example.com,otro@example.com

# --- MongoDB ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=blog
MONGODB_DB=blog

# --- Servidor / CORS ---
PORT=8080
FRONTEND_ORIGIN=http://localhost:4200
# Lista de proxies de confianza separados por comas (vacío = no confiar en ninguno).
TRUSTED_PROXIES=

# --- S3 / AWS ---
S3_BUCKET=your-bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
